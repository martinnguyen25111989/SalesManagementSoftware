<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Pos.Client.UI.ViewModels"
             xmlns:auth="using:Pos.Application.Auth"
             mc:Ignorable="d" d:DesignWidth="1070" d:DesignHeight="800"
             x:Class="Pos.Client.UI.Views.UsersView"
             x:DataType="vm:UsersViewModel">

    <Design.DataContext>
        <vm:UsersViewModel/>
    </Design.DataContext>

    <Grid ColumnDefinitions="360,*" Background="{StaticResource Page}">

        <!-- Form tạo người dùng -->
        <Border Grid.Column="0" Background="White" Margin="14" CornerRadius="12"
                BorderBrush="{StaticResource Line}" BorderThickness="1">
            <ScrollViewer>
                <StackPanel Margin="18" Spacing="2">
                    <TextBlock Text="Thêm người dùng" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,0,0,8"/>

                    <TextBlock Text="Họ tên *" Classes="fld"/>
                    <TextBox Text="{Binding FullName}" PlaceholderText="VD: Nguyễn Văn A"/>

                    <TextBlock Text="Tên đăng nhập *" Classes="fld"/>
                    <TextBox Text="{Binding Username}" PlaceholderText="VD: cashier01"/>

                    <TextBlock Text="Mật khẩu (≥ 6 ký tự) *" Classes="fld"/>
                    <TextBox Text="{Binding Password}" PasswordChar="●"/>

                    <TextBlock Text="Vai trò (cấp quyền) *" Classes="fld"/>
                    <ComboBox ItemsSource="{Binding Roles}" SelectedItem="{Binding SelectedRole}"/>
                    <TextBlock Text="Vai trò quyết định tập quyền (RBAC) theo B2."
                               Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="2,4,0,0"/>

                    <Button Content="TẠO NGƯỜI DÙNG" Classes="primary block" Margin="0,16,0,0"
                            IsEnabled="{Binding !IsBusy}" Command="{Binding SaveCommand}"/>

                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,10"
                               Foreground="{StaticResource BrandDark}" FontWeight="SemiBold"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Danh sách người dùng -->
        <Border Grid.Column="1" Background="White" Margin="0,14,14,14" CornerRadius="12"
                BorderBrush="{StaticResource Line}" BorderThickness="1">
            <Grid RowDefinitions="Auto,Auto,*">
                <TextBlock Grid.Row="0" Text="Tài khoản &amp; phân quyền" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource Ink}" Margin="16,14,16,8"/>

                <Border Grid.Row="1" Background="#F6F8F9" BorderBrush="{StaticResource Line}" BorderThickness="0,1">
                    <Grid ColumnDefinitions="160,*,200,90,110" Margin="16,8">
                        <TextBlock Grid.Column="0" Text="Đăng nhập" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                        <TextBlock Grid.Column="1" Text="Họ tên" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                        <TextBlock Grid.Column="2" Text="Vai trò" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                        <TextBlock Grid.Column="3" Text="Trạng thái" FontWeight="Bold" Foreground="{StaticResource Muted}" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2">
                    <ItemsControl ItemsSource="{Binding Users}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="auth:UserListItem">
                                <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="0,8">
                                    <Grid ColumnDefinitions="160,*,200,90,110" Margin="16,0">
                                        <TextBlock Grid.Column="0" Text="{Binding Username}" Foreground="{StaticResource Ink}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding FullName}" Foreground="{StaticResource Ink}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Roles}" Foreground="{StaticResource BrandDark}" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="3" Text="{Binding IsActive}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Muted}" FontSize="12"/>
                                        <Button Grid.Column="4" Content="Khóa/Mở" Classes="chip secondary" VerticalAlignment="Center" HorizontalAlignment="Right"
                                                Command="{Binding $parent[ItemsControl].((vm:UsersViewModel)DataContext).ToggleActiveCommand}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
