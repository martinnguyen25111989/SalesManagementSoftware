<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Pos.Client.UI.ViewModels"
             xmlns:conv="using:Pos.Client.UI.Converters"
             xmlns:cat="using:Pos.Application.Catalog.Queries"
             mc:Ignorable="d" d:DesignWidth="1070" d:DesignHeight="800"
             x:Class="Pos.Client.UI.Views.ProductsView"
             x:DataType="vm:ProductsViewModel">

    <UserControl.Resources>
        <conv:VndConverter x:Key="Vnd"/>
    </UserControl.Resources>

    <Grid ColumnDefinitions="360,*" Background="{StaticResource Page}">

        <!-- Form tạo sản phẩm -->
        <Border Grid.Column="0" Background="White" Margin="14" CornerRadius="12"
                BorderBrush="{StaticResource Line}" BorderThickness="1">
            <ScrollViewer>
                <StackPanel Margin="18" Spacing="2">
                    <TextBlock Text="Thêm hàng hóa" FontSize="18" FontWeight="Bold" Foreground="{StaticResource Ink}" Margin="0,0,0,8"/>

                    <TextBlock Text="Tên hàng hóa *" Classes="fld"/>
                    <TextBox Text="{Binding Name}" PlaceholderText="VD: Coca-Cola lon 330ml"/>

                    <TextBlock Text="Mã SKU *" Classes="fld"/>
                    <TextBox Text="{Binding Sku}" PlaceholderText="VD: NGK001"/>

                    <TextBlock Text="Mã vạch (tùy chọn)" Classes="fld"/>
                    <TextBox Text="{Binding Barcode}" PlaceholderText="EAN-13..."/>

                    <TextBlock Text="Ngành hàng *" Classes="fld"/>
                    <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding Category}"
                              IsTextSearchEnabled="True"/>
                    <TextBox Text="{Binding Category}" PlaceholderText="...hoặc gõ ngành hàng mới" Margin="0,4,0,0"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Đơn vị" Classes="fld"/>
                            <TextBox Text="{Binding BaseUnit}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Thuế VAT" Classes="fld"/>
                            <ComboBox ItemsSource="{Binding TaxRates}" SelectedItem="{Binding SelectedTaxRate}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:VatOption">
                                        <TextBlock Text="{Binding Label}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Giá bán (đ) *" Classes="fld"/>
                    <TextBox Text="{Binding Price}" TextAlignment="Right"/>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tồn kho ban đầu" Classes="fld"/>
                            <TextBox Text="{Binding InitialStock}" TextAlignment="Right"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Giá vốn (đ)" Classes="fld"/>
                            <TextBox Text="{Binding InitialCost}" TextAlignment="Right"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="Tồn ban đầu chỉ ghi khi tạo mới; để trống nếu nhập hàng sau."
                               Foreground="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="2,4,0,0"/>

                    <CheckBox Content="Đang kinh doanh" IsChecked="{Binding IsActive}" Margin="0,10,0,0"/>

                    <Button Content="LƯU HÀNG HÓA" Classes="primary block" Margin="0,14,0,0"
                            IsEnabled="{Binding !IsBusy}" Command="{Binding SaveCommand}"/>

                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,10"
                               Foreground="{StaticResource BrandDark}" FontWeight="SemiBold"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Danh sách hàng hóa -->
        <Border Grid.Column="1" Background="White" Margin="0,14,14,14" CornerRadius="12"
                BorderBrush="{StaticResource Line}" BorderThickness="1">
            <Grid RowDefinitions="Auto,Auto,*">
                <TextBlock Grid.Row="0" Text="Danh mục hàng hóa" FontSize="16" FontWeight="Bold"
                           Foreground="{StaticResource Ink}" Margin="16,14,16,8"/>

                <Border Grid.Row="1" Background="#F6F8F9" BorderBrush="{StaticResource Line}" BorderThickness="0,1">
                    <Grid ColumnDefinitions="90,*,150,90,110,80" Margin="16,8">
                        <TextBlock Grid.Column="0" Text="SKU" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                        <TextBlock Grid.Column="1" Text="Tên hàng" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                        <TextBlock Grid.Column="2" Text="Ngành hàng" FontWeight="Bold" Foreground="{StaticResource Muted}"/>
                        <TextBlock Grid.Column="3" Text="Tồn" FontWeight="Bold" Foreground="{StaticResource Muted}" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="4" Text="Giá bán" FontWeight="Bold" Foreground="{StaticResource Muted}" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="5" Text="Bán" FontWeight="Bold" Foreground="{StaticResource Muted}" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2">
                    <ItemsControl ItemsSource="{Binding Products}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="cat:AdminProductItem">
                                <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="0,8">
                                    <Grid ColumnDefinitions="90,*,150,90,110,80" Margin="16,0">
                                        <TextBlock Grid.Column="0" Text="{Binding Sku}" Foreground="{StaticResource Muted}" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource Ink}" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Category}" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding OnHand}" Foreground="{StaticResource Ink}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Price, Converter={StaticResource Vnd}}" FontWeight="Bold" Foreground="{StaticResource BrandDark}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Text="{Binding IsActive}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Muted}" FontSize="12"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
