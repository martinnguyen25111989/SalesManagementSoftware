<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Pos.Client.UI.ViewModels"
             xmlns:conv="using:Pos.Client.UI.Converters"
             xmlns:cat="using:Pos.Application.Catalog.Queries"
             mc:Ignorable="d" d:DesignWidth="1070" d:DesignHeight="800"
             x:Class="Pos.Client.UI.Views.InventoryView"
             x:DataType="vm:InventoryViewModel">

    <UserControl.Resources>
        <conv:VndConverter x:Key="Vnd"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*" Background="{StaticResource Page}" Margin="16">

        <!-- Header + tổng giá trị tồn -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="2,0,2,14">
            <StackPanel Grid.Column="0">
                <TextBlock Text="Tồn kho theo chi nhánh" Classes="h1"/>
                <TextBlock Classes="subtitle">
                    <Run Text="{Binding LineCount}"/><Run Text=" mặt hàng"/>
                </TextBlock>
            </StackPanel>
            <Border Grid.Column="1" Classes="card" Padding="14,9" Margin="0,0,10,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Giá trị tồn (theo giá bán):" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
                    <TextBlock FontWeight="Bold" Foreground="{StaticResource BrandDark}" VerticalAlignment="Center">
                        <Run Text="{Binding TotalStockValue, Converter={StaticResource Vnd}}"/><Run Text=" đ"/>
                    </TextBlock>
                </StackPanel>
            </Border>
            <TextBox Grid.Column="2" Text="{Binding SearchText}" PlaceholderText="Tìm hàng (tên/SKU)..."
                     Width="240" VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="1" Classes="card">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0" Background="{StaticResource Header}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" CornerRadius="14,14,0,0">
                    <Grid ColumnDefinitions="110,*,160,110,130,140" Margin="16,11">
                        <TextBlock Grid.Column="0" Text="SKU" Classes="colhead"/>
                        <TextBlock Grid.Column="1" Text="Tên hàng" Classes="colhead"/>
                        <TextBlock Grid.Column="2" Text="Ngành hàng" Classes="colhead"/>
                        <TextBlock Grid.Column="3" Text="Tồn" Classes="colhead" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="4" Text="Giá bán" Classes="colhead" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="5" Text="Giá trị tồn" Classes="colhead" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="cat:AdminProductItem">
                                <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="0,8">
                                    <Grid ColumnDefinitions="110,*,160,110,130,140" Margin="16,0">
                                        <TextBlock Grid.Column="0" Text="{Binding Sku}" Foreground="{StaticResource Muted}" FontSize="12" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{StaticResource Ink}" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Category}" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding OnHand}" FontWeight="Bold" Foreground="{StaticResource Ink}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Price, Converter={StaticResource Vnd}}" Foreground="{StaticResource Ink}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="5" Foreground="{StaticResource BrandDark}" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   Text="{Binding StockValue, Converter={StaticResource Vnd}}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
