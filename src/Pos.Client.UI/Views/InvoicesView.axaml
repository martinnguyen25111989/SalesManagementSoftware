<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Pos.Client.UI.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1070" d:DesignHeight="800"
             x:Class="Pos.Client.UI.Views.InvoicesView"
             x:DataType="vm:InvoicesViewModel">

    <Grid ColumnDefinitions="*,340" Background="{StaticResource Page}" Margin="16">

        <!-- Bảng kê HĐĐT -->
        <Grid Grid.Column="0" RowDefinitions="Auto,Auto,*" Margin="0,0,14,0">
            <StackPanel Grid.Row="0" Margin="2,0,2,14">
                <TextBlock Text="Hóa đơn điện tử (HĐĐT-MTT)" Classes="h1"/>
                <TextBlock Text="Bảng kê chứng từ &amp; trạng thái mã cơ quan thuế (B11)." Classes="subtitle"/>
            </StackPanel>

            <!-- KPI -->
            <Grid Grid.Row="1" ColumnDefinitions="*,*,*" Margin="0,0,0,14">
                <Border Grid.Column="0" Classes="card" Padding="16" Margin="0,0,6,0">
                    <StackPanel><TextBlock Text="Đã cấp mã" Classes="subtitle"/><TextBlock Text="{Binding IssuedCount}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource BrandDark}"/></StackPanel>
                </Border>
                <Border Grid.Column="1" Classes="card" Padding="16" Margin="6,0">
                    <StackPanel><TextBlock Text="Chờ phát hành" Classes="subtitle"/><TextBlock Text="{Binding PendingCount}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Warn}"/></StackPanel>
                </Border>
                <Border Grid.Column="2" Classes="card" Padding="16" Margin="6,0,0,0">
                    <StackPanel><TextBlock Text="Bị từ chối" Classes="subtitle"/><TextBlock Text="{Binding RejectedCount}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource Danger}"/></StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Classes="card">
                <Grid RowDefinitions="Auto,*">
                    <Border Grid.Row="0" Background="{StaticResource Header}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" CornerRadius="14,14,0,0">
                        <Grid ColumnDefinitions="150,110,110,130,*" Margin="20,11">
                            <TextBlock Grid.Column="0" Text="Số đơn" Classes="colhead"/>
                            <TextBlock Grid.Column="1" Text="Loại" Classes="colhead"/>
                            <TextBlock Grid.Column="2" Text="Trạng thái" Classes="colhead"/>
                            <TextBlock Grid.Column="3" Text="Mã CQT" Classes="colhead"/>
                            <TextBlock Grid.Column="4" Text="Số HĐ / Ký hiệu / Ghi chú" Classes="colhead"/>
                        </Grid>
                    </Border>
                    <ScrollViewer Grid.Row="1">
                        <ListBox ItemsSource="{Binding Invoices}" SelectedItem="{Binding Selected}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:InvoiceRow">
                                    <Grid ColumnDefinitions="150,110,110,130,*">
                                        <TextBlock Grid.Column="0" Text="{Binding OrderNumber}" Foreground="{StaticResource Ink}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding TypeText}" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding StatusText}" Foreground="{StaticResource BrandDark}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{Binding CqtCode}" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="4" VerticalAlignment="Center">
                                            <TextBlock Foreground="{StaticResource Ink}"><Run Text="{Binding InvoiceNo}"/><Run Text="  "/><Run Text="{Binding Serial}"/></TextBlock>
                                            <TextBlock Text="{Binding ErrorMessage}" Foreground="#C0392B" FontSize="11" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Panel hành động -->
        <ScrollViewer Grid.Column="1">
            <StackPanel Spacing="12">
                <!-- Phát hành -->
                <Border Classes="card" Padding="16">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Phát hành cho đơn" Classes="h2" Margin="0,0,0,4"/>
                        <TextBox Text="{Binding IssueOrderNumber}" PlaceholderText="Số hóa đơn"/>
                        <TextBlock Text="Người mua (nếu lấy HĐ có MST)" Classes="fld"/>
                        <TextBox Text="{Binding BuyerName}" PlaceholderText="Tên người mua"/>
                        <TextBox Text="{Binding BuyerTaxCode}" PlaceholderText="MST người mua" Margin="0,6,0,0"/>
                        <Button Content="Phát hành HĐĐT" Classes="primary" Command="{Binding IssueForOrderCommand}"
                                HorizontalAlignment="Right" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Hàng đợi offline -->
                <Border Classes="card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Hàng đợi offline" Classes="h2"/>
                        <TextBlock Text="Phát hành lần lượt các HĐ còn chờ khi đã có mạng (idempotent theo đơn)." Foreground="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap"/>
                        <Button Content="Xử lý hàng đợi" Classes="secondary" Command="{Binding ProcessPendingCommand}"
                                HorizontalAlignment="Right" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Điều chỉnh / thay thế / hủy -->
                <Border Classes="card" Padding="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Điều chỉnh / Thay thế / Hủy" Classes="h2"/>
                        <TextBlock Text="{Binding Selected.OrderNumber, StringFormat='HĐ đang chọn: {0}'}" Foreground="{StaticResource BrandDark}" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding ReviseReason}" PlaceholderText="Lý do (bắt buộc)"/>
                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" Margin="0,4,0,0">
                            <Button Content="Điều chỉnh" Classes="secondary chip" Command="{Binding ReviseCommand}" CommandParameter="Adjust"/>
                            <Button Content="Thay thế" Classes="secondary chip" Command="{Binding ReviseCommand}" CommandParameter="Replace"/>
                            <Button Content="Hủy" Classes="danger chip" Command="{Binding ReviseCommand}" CommandParameter="Cancel"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource BrandDark}" TextWrapping="Wrap" Margin="2"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
