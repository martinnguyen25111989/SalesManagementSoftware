<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Pos.Client.UI.App"
             xmlns:local="using:Pos.Client.UI"
             RequestedThemeVariant="Light">
             <!-- POS dùng nền sáng (giống KiotViet); ép Light để text không bị trắng trên nền trắng khi máy ở Dark mode. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <!-- ── Bảng màu thương hiệu (design system dùng chung toàn app) ───────── -->
        <SolidColorBrush x:Key="Brand" Color="#0E9D8A"/>
        <SolidColorBrush x:Key="BrandDark" Color="#0B7E6F"/>
        <SolidColorBrush x:Key="BrandLight" Color="#E3F4F1"/>
        <SolidColorBrush x:Key="Ink" Color="#222A30"/>
        <SolidColorBrush x:Key="Muted" Color="#8A9098"/>
        <SolidColorBrush x:Key="Line" Color="#E6EAEE"/>
        <SolidColorBrush x:Key="Page" Color="#EEF1F4"/>
        <SolidColorBrush x:Key="Header" Color="#F6F8F9"/>
        <SolidColorBrush x:Key="Danger" Color="#D64541"/>
        <SolidColorBrush x:Key="DangerDark" Color="#B5352F"/>
        <SolidColorBrush x:Key="Warn" Color="#E67E22"/>
        <SolidColorBrush x:Key="Soft" Color="#EEF2F4"/>
        <SolidColorBrush x:Key="SoftHover" Color="#E2E8EB"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!-- ════════════════════════════════════════════════════════════════════
             DESIGN SYSTEM — kiểu dùng chung để mọi màn đồng nhất (nút, ô nhập,
             thẻ, tiêu đề). Tránh mỗi View tự đặt kích thước → nút lệch nhau.
        ═════════════════════════════════════════════════════════════════════ -->

        <!-- ── Typography ──────────────────────────────────────────────────── -->
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
        </Style>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
        </Style>
        <Style Selector="TextBlock.subtitle">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
        </Style>
        <!-- Nhãn ô nhập (giữ tên .fld cho tương thích các màn cũ) -->
        <Style Selector="TextBlock.fld, TextBlock.field">
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="2,8,0,3"/>
        </Style>
        <Style Selector="TextBlock.colhead">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
        </Style>

        <!-- ── Thẻ / panel ─────────────────────────────────────────────────── -->
        <Style Selector="Border.card">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BorderBrush" Value="{StaticResource Line}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BoxShadow" Value="0 6 18 0 #0F1A2A33"/>
        </Style>

        <!-- ── Ô nhập đồng nhất ────────────────────────────────────────────── -->
        <Style Selector="TextBox">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="ComboBox">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>
        <Style Selector="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="MinHeight" Value="32"/>
        </Style>

        <!-- ── Nút: kích thước cơ sở dùng chung (mọi nút bo góc & padding đều) ─ -->
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button:disabled">
            <Setter Property="Opacity" Value="0.5"/>
        </Style>

        <!-- Nút chính (hành động chủ đạo) -->
        <Style Selector="Button.primary /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Brand}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrandDark}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrandDark}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Nút phụ (nền nhạt) -->
        <Style Selector="Button.secondary /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Soft}"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SoftHover}"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
        </Style>
        <Style Selector="Button.secondary:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SoftHover}"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
        </Style>

        <!-- Nút nguy hiểm (hủy / hoàn / đóng ca) -->
        <Style Selector="Button.danger /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Button.danger:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerDark}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.danger:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource DangerDark}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Nút viền (nhấn nhẹ) -->
        <Style Selector="Button.ghost /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource BrandDark}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Brand}"/>
            <Setter Property="BorderThickness" Value="1.4"/>
            <Setter Property="CornerRadius" Value="10"/>
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrandLight}"/>
            <Setter Property="Foreground" Value="{StaticResource BrandDark}"/>
        </Style>

        <!-- Biến thể kích thước -->
        <Style Selector="Button.block">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
        <Style Selector="Button.lg">
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="12"/>
        </Style>
        <Style Selector="Button.chip">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="FontSize" Value="12.5"/>
        </Style>

        <!-- ── Hàng dữ liệu trong danh sách (ListBox) ──────────────────────── -->
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="4,1"/>
        </Style>
        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource BrandLight}"/>
        </Style>
        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{StaticResource Header}"/>
        </Style>
    </Application.Styles>
</Application>
