# .env.example — Template biến môi trường dự án POS
# Copy thành .env (đã được .gitignore) và điền giá trị thật. KHÔNG commit .env.

# ── Database ───────────────────────────────────────────────
# POSTGRES_PORT: host port map ra Postgres. Mặc định 5432; máy này dùng 5433
# (port 5432 đã bị chiếm). Đổi lại 5432 nếu máy bạn trống.
POSTGRES_DB=posdb
POSTGRES_USER=posuser
POSTGRES_PASSWORD=
POSTGRES_PORT=5433
ConnectionStrings__Postgres=Host=localhost;Port=5433;Database=posdb;Username=posuser;Password=
ConnectionStrings__Redis=localhost:6379

# ── JWT (đặt SecretKey đủ dài, ngẫu nhiên) ────────────────
Jwt__Issuer=PosSystem
Jwt__Audience=PosClient
Jwt__SecretKey=
Jwt__AccessTokenMinutes=30
Jwt__RefreshTokenDays=14

# ── Hóa đơn điện tử: EasyInvoice (SoftDreams) ─────────────
# ⚠️ Lấy từ tài khoản tích hợp SoftDreams. Xác nhận field/URL theo tài liệu API.
EInvoice__Provider=EasyInvoice
EInvoice__BaseUrl=
EInvoice__Username=
EInvoice__Password=
EInvoice__SellerTaxCode=
EInvoice__TemplateCode=1
EInvoice__InvoiceSeries=C25MAA

# ── Khác ──────────────────────────────────────────────────
DOTNET_ENVIRONMENT=Development
